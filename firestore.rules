rules_version = '2';

// Model i uzasadnienie: work/active/Tumolec.md w vaulcie Obsidian (sekcja "Bezpieczeństwo").
// Brak logowania -- dostęp kontrolowany przez znajomość 6-znakowego roomCode
// (nie do odgadnięcia, 36^6 kombinacji) + participantId trzymany w localStorage klienta.
service cloud.firestore {
  match /databases/{database}/documents {

    function isValidNickname(nickname) {
      return nickname is string && nickname.size() > 0 && nickname.size() <= 24;
    }

    match /rooms/{roomCode} {
      allow read: if true;
      allow create: if request.resource.data.name is string
        && request.resource.data.name.size() <= 60;
      allow update: if request.resource.data.diff(resource.data)
        .affectedKeys().hasOnly(['activeFeature'])
        && request.resource.data.activeFeature in ['swipe', 'coinflip', 'wheel'];

      match /participants/{participantId} {
        allow read: if true;
        allow create: if isValidNickname(request.resource.data.nickname)
          && (!('steamLibraryAppIds' in request.resource.data)
              || (request.resource.data.steamLibraryAppIds is list
                  && request.resource.data.steamLibraryAppIds.size() <= 3000));
        allow update, delete: if false;
      }

      match /games/{steamAppId} {
        allow read: if true;
        allow create: if request.resource.data.steamAppId is number
          && request.resource.data.addedBy is string
          && request.resource.data.status == 'active';
        // Tylko zmiana statusu (played/removed) -- nie edycja addedBy/steamAppId.
        allow update: if request.resource.data.diff(resource.data)
          .affectedKeys().hasOnly(['status', 'playedAt'])
          && request.resource.data.status in ['active', 'played', 'removed']
          && (request.resource.data.playedAt == null || request.resource.data.playedAt is timestamp);
        allow delete: if false;
      }

      match /eliminationRounds/{roundId} {
        allow read: if true;
        // Logika rund liczona po stronie klienta (Faza 1, brak logowania) --
        // nie da się zweryfikować KTO pisze, ale kształt zapisu jest pilnowany,
        // żeby jeden zepsuty/złośliwy klient nie mógł nadpisać rundy dowolnymi
        // danymi (np. wymusić zwycięzcę bez przejścia przez swipes).
        allow create: if request.resource.data.roundNumber is number
          && request.resource.data.poolAtStart is list
          && request.resource.data.sessionId is string
          && request.resource.data.status == 'voting';
        allow update: if request.resource.data.diff(resource.data)
          .affectedKeys().hasOnly(['status', 'survivors'])
          && request.resource.data.status in ['voting', 'finished']
          && (request.resource.data.survivors is list || request.resource.data.survivors == null);
        allow delete: if false;

        match /swipes/{swipeId} {
          allow read: if true;
          // swipeId musi być zbudowany jako `${participantId}_${steamAppId}` --
          // to uniemożliwia głosowanie za kogoś innego bez znajomości cudzego participantId.
          allow create: if swipeId == request.resource.data.participantId + '_' + string(request.resource.data.steamAppId)
            && request.resource.data.direction in ['left', 'right'];
          allow update, delete: if false; // głos jest ostateczny
        }
      }

      match /session/state {
        allow read: if true;
        allow write: if true; // stan mini-gier (moneta/koło), niski risk, grupa 2-4 znajomych
      }
    }

    match /steam_cache/{steamAppId} {
      allow read: if true;
      // ponytail: walidowany zapis zamiast Firebase Admin SDK + service account --
      // to publiczny, nieosobowy cache metadanych ze Steama (nazwa/okładka/tagi),
      // nie dane użytkownika, więc niski koszt błędu przy złym zapisie. Upgrade
      // path jeśli kiedyś potrzebny ściślejszy zapis tylko-serwerowy: Admin SDK
      // w API routes + `allow write: if false` tutaj.
      // `hasOnly` zamyka pole na dokładnie te klucze -- bez tego dowolny
      // nieautoryzowany klient mógłby dopisać/podmienić headerImageUrl,
      // steamUrl czy shortDescription bez żadnej walidacji typu.
      allow write: if request.resource.data.keys().hasOnly([
          'name', 'headerImageUrl', 'steamUrl', 'shortDescription',
          'reviewSummary', 'reviewScorePercent', 'tags',
          'minRequirements', 'recRequirements', 'cachedAt',
          'developers', 'releaseDate', 'screenshots',
          'trailerHlsUrl', 'trailerThumbnail', 'totalReviews',
        ])
        && request.resource.data.name is string
        && request.resource.data.headerImageUrl is string
        && request.resource.data.steamUrl is string
        && request.resource.data.shortDescription is string
        && request.resource.data.reviewSummary is string
        && request.resource.data.reviewScorePercent is number
        && request.resource.data.tags is list
        && request.resource.data.minRequirements is string
        && request.resource.data.recRequirements is string
        && request.resource.data.cachedAt is number
        && request.resource.data.developers is list
        && (request.resource.data.releaseDate == null || request.resource.data.releaseDate is map)
        && request.resource.data.screenshots is list
        && (request.resource.data.trailerHlsUrl == null || request.resource.data.trailerHlsUrl is string)
        && (request.resource.data.trailerThumbnail == null || request.resource.data.trailerThumbnail is string)
        && request.resource.data.totalReviews is number;
    }

    match /packages/{packageId} {
      allow read: if true;
      // Paczki tworzone przez klientów (brak logowania). hasOnly zamyka zapis
      // na dokładnie te trzy pola; niezmienne po utworzeniu.
      allow create: if request.resource.data.keys().hasOnly(['name', 'createdAt', 'gameIds'])
        && request.resource.data.name is string
        && request.resource.data.name.size() <= 60
        && request.resource.data.gameIds is list
        && request.resource.data.gameIds.size() <= 200;
      allow update, delete: if false;
    }
  }
}
